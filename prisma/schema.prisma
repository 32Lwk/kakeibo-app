generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MembershipRole {
  owner
  editor
  viewer
}

enum TransactionType {
  expense
  income
}

enum GeneratedKind {
  recurring
  carryover_account
  carryover_category
}

enum ReceiptStatus {
  pending
  ocr_done
  structured_done
  confirmed
  failed
}

enum JoinRequestStatus {
  pending
  approved
  rejected
}

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  emailVerified DateTime?
  passwordHash String?
  name         String?
  image        String?
  isAdmin      Boolean  @default(false)
  weekStartsOn Int      @default(0) // 0=Sun, 1=Mon ... (user setting)
  theme        String   @default("system") // system | light | dark
  accent       String?  // e.g. "indigo" (optional)
  transactionSort String @default("date_desc") // date_desc | date_asc | amount_desc | amount_asc
  summaryOrder String   @default("expense_first") // expense_first | income_first
  carryoverEnabled Boolean @default(true)
  carryoverNote  String? // freeform memo for rules (MVP)
  recurringAutoApply Boolean @default(true)
  /// 複数世帯に所属する場合の「現在の家計簿」（未設定時は最古のメンバーシップを使用）
  preferredHouseholdId String?
  /// 現在の家計簿内で表示・入力に使うレイヤー（未設定時は sort 順で先頭）
  preferredLayerId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts    Account[]
  sessions    Session[]
  memberships Membership[]
  auditLogs   AuditLog[]
  imports     Import[]
  duplicateIgnores DuplicateIgnore[]
  joinRequests HouseholdJoinRequest[] @relation("JoinRequestUser")
  decidedJoinRequests HouseholdJoinRequest[] @relation("JoinRequestDecider")
}

model Household {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships  Membership[]
  categories   Category[]
  transactions Transaction[]
  recurringRules RecurringRule[]
  receipts     Receipt[]
  imports      Import[]
  attachments  Attachment[]
  duplicateIgnores DuplicateIgnore[]
  invites      HouseholdInvite[]
  joinRequests HouseholdJoinRequest[]
  layers       HouseholdLayer[]
}

model HouseholdLayer {
  id          String   @id @default(cuid())
  name        String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  transactions   Transaction[]
  recurringRules RecurringRule[]
  receipts       Receipt[]

  @@index([householdId, sortOrder])
}

model HouseholdInvite {
  id              String         @id @default(cuid())
  token           String         @unique
  householdId     String
  household       Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  role            MembershipRole @default(editor)
  createdByUserId String
  expiresAt       DateTime
  createdAt       DateTime       @default(now())

  @@index([householdId])
}

model HouseholdJoinRequest {
  id            String            @id @default(cuid())
  status        JoinRequestStatus @default(pending)
  requestedRole MembershipRole
  createdAt     DateTime          @default(now())
  decidedAt     DateTime?

  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation("JoinRequestUser", fields: [userId], references: [id], onDelete: Cascade)

  decidedByUserId String?
  decidedByUser   User?   @relation("JoinRequestDecider", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  inviteToken String?

  @@unique([householdId, userId, status])
  @@index([householdId, status, createdAt])
}

model Membership {
  id        String         @id @default(cuid())
  role      MembershipRole
  createdAt DateTime       @default(now())

  userId      String
  householdId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([userId, householdId])
  @@index([householdId])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  sortOrder Int      @default(0)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  splits       TransactionSplit[]
  receiptItems ReceiptItem[]
  recurringRules RecurringRule[]

  @@unique([householdId, name])
  @@index([householdId])
}

model Transaction {
  id           String          @id @default(cuid())
  type         TransactionType
  purchaseDate DateTime
  totalAmount  Int
  memo         String?
  accountType  String? // "cash" | "bank" | "credit" | "investment" (MVP: freeform)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // generated (recurring/carryover) - for idempotency
  generatedKind  GeneratedKind?
  generatedMonth String? // YYYY-MM
  generatedKey   String? // ruleId / accountType / categoryId

  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  layerId String
  layer   HouseholdLayer @relation(fields: [layerId], references: [id], onDelete: Restrict)

  splits      TransactionSplit[]
  refundFrom  Refund?            @relation("RefundOriginal")
  refundTo    Refund?            @relation("RefundRefund")
  attachments Attachment[]

  recurringRuleId String?
  recurringRule   RecurringRule? @relation(fields: [recurringRuleId], references: [id], onDelete: SetNull)

  @@index([householdId, layerId, purchaseDate])
  @@unique([householdId, layerId, generatedKind, generatedMonth, generatedKey])
}

model RecurringRule {
  id         String   @id @default(cuid())
  isActive   Boolean  @default(true)
  type       TransactionType
  dayOfMonth Int      // 1-28
  amount     Int      // positive
  memo       String?
  accountType String? // cash/bank/etc
  startMonth String   @default("1970-01") // YYYY-MM
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  layerId String
  layer   HouseholdLayer @relation(fields: [layerId], references: [id], onDelete: Restrict)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  transactions Transaction[]

  @@index([householdId, layerId, isActive])
}

model TransactionSplit {
  id        String   @id @default(cuid())
  amount    Int
  note      String?
  createdAt DateTime @default(now())

  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([transactionId])
  @@index([categoryId])
}

model Refund {
  id        String   @id @default(cuid())
  reason    String?
  createdAt DateTime @default(now())

  originalTransactionId String @unique
  refundTransactionId   String @unique

  originalTransaction Transaction @relation("RefundOriginal", fields: [originalTransactionId], references: [id], onDelete: Cascade)
  refundTransaction   Transaction @relation("RefundRefund", fields: [refundTransactionId], references: [id], onDelete: Cascade)
}

model Receipt {
  id             String        @id @default(cuid())
  status         ReceiptStatus @default(pending)
  purchaseDate   DateTime?
  storeName      String?
  totalAmount    Int?
  ocrText        String?
  structuredJson Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  layerId String
  layer   HouseholdLayer @relation(fields: [layerId], references: [id], onDelete: Restrict)

  items       ReceiptItem[]
  attachments Attachment[]

  @@index([householdId, layerId, createdAt])
}

model ReceiptItem {
  id        String   @id @default(cuid())
  name      String
  quantity  Int?
  unitPrice Int?
  amount    Int
  createdAt DateTime @default(now())

  receiptId String
  receipt   Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([receiptId])
}

model Attachment {
  id           String   @id @default(cuid())
  kind         String // "transaction" | "receipt"
  mimeType     String
  fileName     String?
  gcsObjectKey String
  createdAt    DateTime @default(now())

  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  receiptId String?
  receipt   Receipt? @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([householdId, createdAt])
}

model Import {
  id        String   @id @default(cuid())
  source    String
  fileName  String?
  summary   Json?
  createdAt DateTime @default(now())

  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([householdId, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
}

enum DuplicateIgnoreKind {
  amount
  datetime
}

model DuplicateIgnore {
  id        String              @id @default(cuid())
  kind      DuplicateIgnoreKind
  value     String
  createdAt DateTime            @default(now())

  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([householdId, kind, value])
  @@index([householdId, createdAt])
}

// NextAuth (Prisma adapter) models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
