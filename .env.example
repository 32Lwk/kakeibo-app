# Copy to .env and fill in values. Never commit .env.

# Database (PostgreSQL / Neon — use sslmode=require for Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
# Production / OAuth callbacks (e.g. https://your-domain.com)
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional — for Google sign-in)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Google Photos Picker (optional — used in browser / client component)
# Use the same value as GOOGLE_CLIENT_ID.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# OpenAI — receipt parsing / duplicate suggestions
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Google Cloud Vision — alternative to OpenAI for receipts (optional)
# Either set path to service account JSON:
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"
# Or inline service account (escape newlines in private key as \n):
# GOOGLE_CLIENT_EMAIL=""
# GOOGLE_PRIVATE_KEY=""

# Guardrails (optional)
# AI_CALL_LIMIT_PER_MONTH=""
# RECEIPT_IMAGE_KEEP="true"
# RECEIPT_IMAGE_RETENTION_DAYS=""
